#Summarise the numerical data

summarize_numeric <- function(var, group) {
  df <- data %>%
    select(all_of(c(var,group))) %>%
    drop_na()
  
  ##sense check
  if (nlevels(factor(df[[group]])) < 2) {
    stop(paste("Grouping variable", group, "must have 2 levels to proceed. If not, check underlying file"))
  }
  
  
  
  #Function to summarise
  
  get_stats <- function(x) {
    tibble(
      mean = round(mean(x), 2),
      sd = round(sd(x), 2),
      median = round(median(x), 2),
      Q1 = round(quantile(x, 0.25), 2),
      Q3 = round(quantile(x, 0.75), 2),
      IQR = round(IQR(x), 2)
    )
  }
  
  all_stats <- df %>%
    summarise (get_stats(.data[[var]])) %>%
    mutate(Group = "All")
  
  by_group <- df %>%
    group_by(.data[[group]]) %>%
    summarise(get_stats(.data[[var]]), .group = "drop") %>%
    rename(Group = 1)
  
  test <- kruskal.test(reformulate(group, var), data = df)
  pval <- round(test$p.value, 3)
  
  bind_rows(all_stats, by_group) %>%
    mutate(variable = var,
           value = paste0(
             mean, " (", sd, "); ",
             median, " (", Q1, ", ", Q3, ")"
           ),
           p = if_else(Group == "All", as.character(pval), "")
    ) %>%
    select(variable, Group, value, p)
}



