#Plot nursing interactions

allowed_types <- c("nurseclinic",  "nursephone", "nursehome")
df <- data %>% filter(type %in% allowed_types)

df_plot <- df %>%
  pivot_longer(
    cols = starts_with("No_") | starts_with("Yes_"),
    names_to = "group", values_to = "count"
  ) %>%
  separate(group, into = c("intervention_status", "care_type"), sep = "_") %>%
  # compute percent **within each (type, care_type, intervention_status)** slice
  group_by(type, care_type, intervention_status) %>%
  mutate(percent = count / sum(count) * 100) %>%
  ungroup()



ggplot(df_plot, aes(x = factor(number), y = percent, fill = factor(number))) +
  geom_col(position = position_dodge(width = 0.9), color = "black") +
  # add counts on top of each bar
  geom_text(
    aes(label = count),
    position = position_dodge(width = 0.9),
    vjust = -0.25,
    size = 3
  ) +
  facet_grid(
    intervention_status ~ type + care_type,
    scales = "free_y"
  ) +
  labs(
    title = "Distribution of Interaction Counts (0–5)\nby CareType & Status",
    x = "Number of Interactions", y = "Percentage",
    fill = "Number"
  ) +
  scale_fill_manual(
    values = number_colors,
    breaks = number_levels
  ) +
  scale_y_continuous(
    labels = percent_format(scale = 1),
    expand = expansion(mult = c(0, 0.1))
  ) +
  theme_grey(base_size = 14) +
  theme(
    strip.placement        = "outside",
    strip.text.y.left      = element_blank(),
    strip.text.y.right     = element_text(angle = 0, hjust = 0),
    strip.text.x           = element_text(angle = 0, vjust = 0.5),
    panel.spacing          = unit(0.5, "lines"),
    plot.margin            = margin(r = 10, l = 10, t = 10, b = 10)
  )




