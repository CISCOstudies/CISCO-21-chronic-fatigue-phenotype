#EQ5D plot
data <- read_csv("Data/EQ5D.csv")


data <- data %>% rename(response = domain)

level_map <- tribble(
  ~response_pattern,                 ~level,
  "no problems|no pain|not anxious",    "1 - No problems",
  "slight problems|slight pain|slightly anxious",    "2 - Slight problems",
  "moderate problems|moderate pain|moderately anxious",  "3 - Moderate problems",
  "severe problems|severe pain|severely anxious",  "4 - Severe problems",
  "unable|extreme|extreme anxiety",     "5 - Extreme / Unable"
)

assign_level <- function(resp) {
  resp_lower <- tolower(resp)
  matched <- level_map %>%
    filter(str_detect(resp_lower, response_pattern)) %>%
    slice(1) %>%
    pull(level)
  if(length(matched) == 0) return(NA_character_) else return(matched)
}

#set colours for levels
level_colors <- c(
  "1 - No problems" = "#B4CFEE",
  "2 - Slight problems" = "#1F5189",
  "3 - Moderate problems" = "#FFE8AE",
  "4 - Severe problems" = "#E37222",
  "5 - Extreme / Unable" = "#981821"
)



data <- data %>%
  mutate(level = map_chr(response, assign_level))

long_data <- data %>%
  pivot_longer(cols = starts_with(c("No_", "Yes_")),
               names_to = "group",
               values_to = "count")

percent_data <- long_data %>%
  group_by(feature, timepoint, group) %>%
  mutate(total = sum(count)) %>%
  ungroup() %>%
  mutate(percentage = ifelse(total > 0, (count / total) * 100, 0)) %>%
  filter(!is.na(level))

percent_data <- percent_data %>%
  mutate(level = factor(level, levels = (names(level_colors))),
         timepoint = factor(timepoint, levels = c("pre", "post")),
         group = factor(group, levels = c("No_Intervention", "No_StandardCare", "Yes_Intervention", "Yes_StandardCare")),
         feature = factor(feature))

#Rename vavriables
group_labels <- c(
  "No_Intervention" = "Intervention",
  "No_StandardCare" = "Standard Care",
  "Yes_Intervention" = "Intervention",
  "Yes_StandardCare" = "Standard Care"
)

feature_labels <- c(
  "mobility" = "Mobility",
  "self-care" = "Self-Care",
  "usual activities" = "Usual Activities",
  "pain discomfort" = "Pain or Discomfort",
  "anxious depressed" = "Anxiety or Depression"
)

#Final plot
ggplot(percent_data, aes(x = timepoint, y = percentage, fill = level)) +
  geom_bar(stat = "identity", position = "dodge", color = "black") +
  facet_grid(group ~ feature, scales = "free_x",
             labeller = labeller(group = group_labels, feature = feature_labels)) +
  scale_fill_manual(values = level_colors, drop = FALSE) +
  labs(title = "EQ-5D Response Levels Distribution Pre and Post Intervention",
       x = "Timepoint",
       y = "% of Participants",
       fill = "Response Level") +
  theme_gray(base_size = 16) +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))



